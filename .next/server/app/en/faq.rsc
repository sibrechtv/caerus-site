2:[["$","section",null,{"id":"$undefined","className":"section-padding bg-background ","children":["$","div",null,{"className":"section-container","children":["$","div",null,{"className":"text-center max-w-3xl mx-auto","children":[["$","h1",null,{"className":"text-display-md lg:text-display-lg font-display font-bold text-foreground","children":"Frequently Asked Questions"}],["$","p",null,{"className":"mt-4 text-lg text-foreground-secondary","children":"Everything you need to know"}]]}]}]}],["$","section",null,{"id":"$undefined","className":"section-padding bg-background-secondary ","children":["$","div",null,{"className":"section-container","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":["$","div",null,{"className":"bg-white rounded-2xl border border-border shadow-soft p-6 lg:p-8","children":["$","$L9",null,{"items":[{"question":"Is this for all levels?","answer":"The program is designed for students with a high school level who are entering EPFL. If you have significant gaps, the program will help you fill them. If you already have a good level, it will strengthen your knowledge."},{"question":"How much time per week?","answer":"Plan for about 5 to 10 hours per week depending on your pace. You can progress at your own speed, but we recommend regularity to properly absorb the concepts."},{"question":"How do the Zoom sessions work?","answer":"Each week, we organize a live session on Zoom. On the agenda: correction of the week's exercises, additional explanations, and your questions. Sessions are recorded if you can't attend."},{"question":"How does private tutoring work?","answer":"Private tutoring is an additional option for those who want individual support. You work directly with a tutor on your specific difficulties. Contact us to learn more about rates."},{"question":"What if I can't attend live?","answer":"Zoom sessions are recorded and available for replay. You can also ask your questions in writing and we'll answer them during the next session or by message."},{"question":"When should I start?","answer":"The program is designed for the summer before EPFL starts, typically from June to September. We recommend starting as early as possible to have time to properly absorb the content."}]}]}]}]}]}],["$","section",null,{"id":"$undefined","className":"section-padding bg-background ","children":["$","div",null,{"className":"section-container","children":["$","div",null,{"className":"text-center max-w-2xl mx-auto","children":[["$","h2",null,{"className":"text-display-sm font-display font-bold text-foreground","children":"Encore des questions ?"}],["$","p",null,{"className":"mt-4 text-foreground-secondary","children":"N'hésitez pas à nous contacter, nous serons ravis de vous répondre."}],["$","div",null,{"className":"mt-8 flex flex-col sm:flex-row items-center justify-center gap-4","children":[["$","$La",null,{"href":"/#contact","children":"Nous contacter"}],["$","$La",null,{"href":"/pricing","variant":"outline","children":"Voir les tarifs"}]]}]]}]}]}]]
d:{"question":"Is this for all levels?","answer":"The program is designed for students with a high school level who are entering EPFL. If you have significant gaps, the program will help you fill them. If you already have a good level, it will strengthen your knowledge."}
e:{"question":"How much time per week?","answer":"Plan for about 5 to 10 hours per week depending on your pace. You can progress at your own speed, but we recommend regularity to properly absorb the concepts."}
f:{"question":"How do the Zoom sessions work?","answer":"Each week, we organize a live session on Zoom. On the agenda: correction of the week's exercises, additional explanations, and your questions. Sessions are recorded if you can't attend."}
10:{"question":"How does private tutoring work?","answer":"Private tutoring is an additional option for those who want individual support. You work directly with a tutor on your specific difficulties. Contact us to learn more about rates."}
11:{"question":"What if I can't attend live?","answer":"Zoom sessions are recorded and available for replay. You can also ask your questions in writing and we'll answer them during the next session or by message."}
12:{"question":"When should I start?","answer":"The program is designed for the summer before EPFL starts, typically from June to September. We recommend starting as early as possible to have time to properly absorb the content."}
