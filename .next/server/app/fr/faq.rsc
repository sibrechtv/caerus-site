2:[["$","section",null,{"id":"$undefined","className":"section-padding bg-background ","children":["$","div",null,{"className":"section-container","children":["$","div",null,{"className":"text-center max-w-3xl mx-auto","children":[["$","h1",null,{"className":"text-display-md lg:text-display-lg font-display font-bold text-foreground","children":"Questions fréquentes"}],["$","p",null,{"className":"mt-4 text-lg text-foreground-secondary","children":"Tout ce que vous devez savoir"}]]}]}]}],["$","section",null,{"id":"$undefined","className":"section-padding bg-background-secondary ","children":["$","div",null,{"className":"section-container","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":["$","div",null,{"className":"bg-white rounded-2xl border border-border shadow-soft p-6 lg:p-8","children":["$","$L9",null,{"items":[{"question":"Est-ce que c'est pour tous les niveaux ?","answer":"Le programme est conçu pour les étudiants qui ont un niveau de gymnase/lycée et qui vont entrer à l'EPFL. Si vous avez des lacunes importantes, le programme vous aidera à les combler. Si vous avez déjà un bon niveau, il renforcera vos acquis."},{"question":"Combien de temps par semaine ?","answer":"Comptez environ 5 à 10 heures par semaine selon votre rythme. Vous pouvez avancer à votre propre cadence, mais nous recommandons une régularité pour bien assimiler les notions."},{"question":"Comment fonctionnent les Zoom ?","answer":"Chaque semaine, nous organisons une séance en direct sur Zoom. Au programme : correction des exercices de la semaine, explications complémentaires, et vos questions. Les séances sont enregistrées si vous ne pouvez pas y assister."},{"question":"Le tutorat privé, c'est comment ?","answer":"Le tutorat privé est une option supplémentaire pour ceux qui souhaitent un accompagnement individuel. Vous travaillez en direct avec un tuteur sur vos difficultés spécifiques. Contactez-nous pour en savoir plus sur les tarifs."},{"question":"Et si je ne peux pas assister en live ?","answer":"Les séances Zoom sont enregistrées et disponibles en replay. Vous pouvez aussi poser vos questions par écrit et nous y répondrons lors de la prochaine séance ou par message."},{"question":"Quand commencer ?","answer":"Le programme est prévu pour l'été avant la rentrée EPFL, généralement de juin à septembre. Nous vous recommandons de commencer le plus tôt possible pour avoir le temps de bien assimiler les contenus."}]}]}]}]}]}],["$","section",null,{"id":"$undefined","className":"section-padding bg-background ","children":["$","div",null,{"className":"section-container","children":["$","div",null,{"className":"text-center max-w-2xl mx-auto","children":[["$","h2",null,{"className":"text-display-sm font-display font-bold text-foreground","children":"Encore des questions ?"}],["$","p",null,{"className":"mt-4 text-foreground-secondary","children":"N'hésitez pas à nous contacter, nous serons ravis de vous répondre."}],["$","div",null,{"className":"mt-8 flex flex-col sm:flex-row items-center justify-center gap-4","children":[["$","$La",null,{"href":"/#contact","children":"Nous contacter"}],["$","$La",null,{"href":"/pricing","variant":"outline","children":"Voir les tarifs"}]]}]]}]}]}]]
d:{"question":"Est-ce que c'est pour tous les niveaux ?","answer":"Le programme est conçu pour les étudiants qui ont un niveau de gymnase/lycée et qui vont entrer à l'EPFL. Si vous avez des lacunes importantes, le programme vous aidera à les combler. Si vous avez déjà un bon niveau, il renforcera vos acquis."}
e:{"question":"Combien de temps par semaine ?","answer":"Comptez environ 5 à 10 heures par semaine selon votre rythme. Vous pouvez avancer à votre propre cadence, mais nous recommandons une régularité pour bien assimiler les notions."}
f:{"question":"Comment fonctionnent les Zoom ?","answer":"Chaque semaine, nous organisons une séance en direct sur Zoom. Au programme : correction des exercices de la semaine, explications complémentaires, et vos questions. Les séances sont enregistrées si vous ne pouvez pas y assister."}
10:{"question":"Le tutorat privé, c'est comment ?","answer":"Le tutorat privé est une option supplémentaire pour ceux qui souhaitent un accompagnement individuel. Vous travaillez en direct avec un tuteur sur vos difficultés spécifiques. Contactez-nous pour en savoir plus sur les tarifs."}
11:{"question":"Et si je ne peux pas assister en live ?","answer":"Les séances Zoom sont enregistrées et disponibles en replay. Vous pouvez aussi poser vos questions par écrit et nous y répondrons lors de la prochaine séance ou par message."}
12:{"question":"Quand commencer ?","answer":"Le programme est prévu pour l'été avant la rentrée EPFL, généralement de juin à septembre. Nous vous recommandons de commencer le plus tôt possible pour avoir le temps de bien assimiler les contenus."}
